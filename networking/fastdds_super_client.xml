<?xml version="1.0" encoding="UTF-8" ?>
<!--
  fastdds_super_client.xml

  FastDDS discovery server configuration for URSULA.
  Used when the Jetson and dev laptop are on different subnets (e.g. over VPN).

  SETUP:
    1. Replace DISCOVERY_SERVER_IP below with the IP address of the machine
       running the FastDDS discovery server (usually the Jetson).
    2. Set this file as the active profile on both machines:
         export FASTRTPS_DEFAULT_PROFILES_FILE=~/ros2_ws/src/ursula/networking/fastdds_super_client.xml
       Add this line to ~/.bashrc so it is set on every login.
    3. Start the discovery server on the Jetson:
         fastdds discovery -i 0 -p 11811

  If both machines are on the same local network, FastDDS multicast discovery
  works automatically and this file is not needed — just set ROS_DOMAIN_ID.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

  <participant profile_name="super_client_profile" is_default_profile="true">
    <rtps>
      <builtin>
        <discovery_config>
          <discoveryProtocol>SUPER_CLIENT</discoveryProtocol>
          <discoveryServersList>
            <RemoteServer prefix="44.53.00.5f.45.50.52.4f.53.49.4d.41">
              <metatrafficUnicastLocatorList>
                <locator>
                  <udpv4>
                    <address>DISCOVERY_SERVER_IP</address>
                    <port>11811</port>
                  </udpv4>
                </locator>
              </metatrafficUnicastLocatorList>
            </RemoteServer>
          </discoveryServersList>
        </discovery_config>

        <metatrafficUnicastLocatorList>
          <locator>
            <udpv4>
              <address>DISCOVERY_SERVER_IP</address>
            </udpv4>
          </locator>
        </metatrafficUnicastLocatorList>

        <initialPeersList>
          <locator>
            <udpv4>
              <address>DISCOVERY_SERVER_IP</address>
              <port>11811</port>
            </udpv4>
          </locator>
        </initialPeersList>

      </builtin>
    </rtps>
  </participant>

</profiles>